def verify_and_install_dependencies(packages):
    print("[DEBUG 02] Inside verify_and_install_dependencies function.")

    missing_or_outdated = []

    for import_name, (pip_name, target_version) in packages.items():

        print(f"[DEBUG 03] Inspecting package: {pip_name}...")

        try:
            current_version = importlib.metadata.version(pip_name)

            print(
                f"[DEBUG 04] Found {pip_name} version {current_version} installed."
            )

            if target_version and current_version != target_version:

                print(f"[DEBUG 05] Version mismatch for '{pip_name}': "
                      f"Need {target_version}.")

                missing_or_outdated.append(f"{pip_name}=={target_version}")

        except importlib.metadata.PackageNotFoundError:

            print(f"[DEBUG 06] Package '{pip_name}' is completely missing.")

            if target_version:
                missing_or_outdated.append(f"{pip_name}=={target_version}")
            else:
                missing_or_outdated.append(pip_name)

    if missing_or_outdated:

        print("[DEBUG 07] Packages queued for install/update: "
              f"{missing_or_outdated}")

        try:

            print("[DEBUG 08] Launching pip subprocess...")

            subprocess.check_call([
                sys.executable,
                "-m",
                "pip",
                "install",
                *missing_or_outdated,
            ])

            print("[DEBUG 09] Pip installation subprocess "
                  "completed successfully.")

        except subprocess.CalledProcessError as e:

            print("\n[CRITICAL ERROR] Automated pip installation "
                  f"failed with exit code {e.returncode}.")

            sys.exit(1)

    else:

        print("[DEBUG 10] All dependencies verified and ready.")


# Run dependency verification before importing packages
verify_and_install_dependencies(REQUIRED_PACKAGES)

