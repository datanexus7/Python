def query_local_sql_server(username, password):

    print("[DEBUG 23] Preparing SQLAlchemy SQL Server connection...")

    try:

        from urllib.parse import quote_plus

        # ----------------------------------------------------------------------
        # Build ODBC connection string
        # ----------------------------------------------------------------------

        odbc_conn_str = ("DRIVER={ODBC Driver 17 for SQL Server};"
                         "SERVER=localhost\\SQLEXPRESS;"
                         "DATABASE=DWConfiguration;"
                         f"UID={username};"
                         f"PWD={password};"
                         "TrustServerCertificate=yes;")

        print("[DEBUG 24] Encoding ODBC connection string...")

        connection_url = ("mssql+pyodbc:///?odbc_connect=" +
                          quote_plus(odbc_conn_str))

        print("[DEBUG 25] Creating SQLAlchemy engine...")

        engine = sqlalchemy.create_engine(connection_url,
                                          pool_pre_ping=True,
                                          future=True)

        query = """
        SELECT
             [id]
            ,[name]
            ,[address]
            ,[database]
            ,[instance]
            ,[active]
            ,[index]
            ,[driveletter]
        FROM [DWConfiguration].[dbo].[compute_node]
        """

        print("[DEBUG 26] Opening SQLAlchemy database connection...")

        with engine.connect() as conn:

            print("[DEBUG 27] SQL connection established. "
                  "Executing query...")

            df = pd.read_sql(sqlalchemy.text(query), conn)

            print(f"[DEBUG 28] Query completed. "
                  f"Rows retrieved: {len(df)}")

        # ------------------------------------------------------------------
        # Release pooled connections
        # ------------------------------------------------------------------

        engine.dispose()

        print("[DEBUG 29] SQLAlchemy engine disposed.")

        return df

    except Exception as e:

        print("\n[CRITICAL ERROR] SQL Server extraction failed.")

        print(f"Error details: {e}")

        sys.exit(1)


