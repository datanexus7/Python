def get_credentials_from_cli(db_path, entry_title, master_password):

    print(f"[DEBUG 15] Preparing KeePassXC extraction "
          f"for entry: '{entry_title}'")

    try:

        cmd_username = [
            "keepassxc-cli",
            "show",
            db_path,
            entry_title,
            "-a",
            "UserName",
        ]

        cmd_password = [
            "keepassxc-cli",
            "show",
            db_path,
            entry_title,
            "-a",
            "Password",
        ]

        print("[DEBUG 16] Extracting username from KeePassXC...")

        proc_user = subprocess.Popen(
            cmd_username,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )

        username, err_user = proc_user.communicate(
            input=f"{master_password}\n")

        print(f"[DEBUG 17] Username extraction completed. "
              f"Return code: {proc_user.returncode}")

        print("[DEBUG 18] Extracting password from KeePassXC...")

        proc_pass = subprocess.Popen(
            cmd_password,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )

        password, err_pass = proc_pass.communicate(
            input=f"{master_password}\n")

        print(f"[DEBUG 19] Password extraction completed. "
              f"Return code: {proc_pass.returncode}")

        if proc_user.returncode != 0:

            raise RuntimeError(f"Username extraction failed: "
                               f"{err_user.strip()}")

        if proc_pass.returncode != 0:

            raise RuntimeError(f"Password extraction failed: "
                               f"{err_pass.strip()}")

        username = username.strip()
        password = password.strip()

        if not username or not password:

            raise RuntimeError("Retrieved credentials are empty.")

        print("[DEBUG 20] Credentials successfully extracted.")

        return username, password

    except FileNotFoundError:

        print("\n[CRITICAL ERROR] keepassxc-cli executable not found.")

        print("Install KeePassXC and ensure keepassxc-cli "
              "is available in PATH.")

        sys.exit(1)

    except Exception as e:

        print("\n[CRITICAL ERROR] KeePassXC extraction failed.")

        print(str(e))

        sys.exit(1)


def prompt_password_gui(db_name):
    """
    Displays secure Windows GUI popup
    for KeePassXC master password.
    """

    print("[DEBUG 21] Opening KeePassXC password dialog...")

    root = tk.Tk()

    root.withdraw()

    # Keep popup above all applications

    root.attributes("-topmost", True)

    password = simpledialog.askstring(
        title="KeePassXC Authentication",
        prompt=f"Enter Master Password for:\n{db_name}",
        show="*",
    )

    root.destroy()

    if not password:

        print("\n[NOTE] Password entry cancelled.")

        sys.exit(0)

    print("[DEBUG 22] Master password captured successfully.")

    return password


